# 로컬 MLX 서버 (OpenAI 호환)
MLX_BASE_URL=http://localhost:8045/v1
# 아래 더미를 실제 키로 교체하세요. (이 값 그대로 두면 인증 실패)
MLX_API_KEY=replace-with-your-key
MLX_MODEL=mlx-community/Qwen3.6-35B-A3B-mxfp8

# PostgreSQL (docker-compose)
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agents

# API 인증 토큰 — 강한 값으로 교체. admin/.env VITE_API_TOKEN과 동일해야 함
API_AUTH_TOKEN=replace-with-a-strong-token

# 부트스트랩 관리자 시드(부팅 시 seed_admin) — **반드시 영속 keep-list 계정**(admin@example.com)으로 둔다.
# dev 서버를 verify032 같은 *테스트* 계정으로 ADMIN_EMAIL 시드하면, --reload 재시작마다 그 테스트 계정이
# 재생성돼 정리(스펙 050)가 무효화된다. 던짐용 계정이 필요하면 tests/_provision_super.py로 즉석 생성·삭제.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpass123
