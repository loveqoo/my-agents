# 기본 채팅/임베딩 모델은 **Mock LLM**(무외부 동작, 응답 canned — 스펙 059). 별도 env 불필요.
# 실 모델(MLX·OpenAI 호환 등)은 여기 env가 아니라 admin Provider UI에서 추가하고 기본 전환한다.

# PostgreSQL (docker-compose)
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/agents

# API 인증 토큰 — 강한 값으로 교체. admin/.env VITE_API_TOKEN과 동일해야 함
API_AUTH_TOKEN=replace-with-a-strong-token

# 부트스트랩 관리자 시드(부팅 시 seed_admin) — **반드시 영속 keep-list 계정**(admin@example.com)으로 둔다.
# dev 서버를 verify032 같은 *테스트* 계정으로 ADMIN_EMAIL 시드하면, --reload 재시작마다 그 테스트 계정이
# 재생성돼 정리(스펙 050)가 무효화된다. 던짐용 계정이 필요하면 tests/_provision_super.py로 즉석 생성·삭제.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpass123

# 세션 쿠키 Secure 플래그(기본 true = HTTPS에서만 저장). 원격 사용자가 Tailscale을 통해 평문 http로
# 접속하면 브라우저가 Secure 쿠키를 드롭해 로그인이 안 잡힌다(Tailscale serve가 raw TCP 패스스루라
# vite는 평문만 말함). 그런 dev 접속을 허용하려면 false. WireGuard가 터널을 암호화하므로 사설 tailnet
# 한정으로 안전. 공개 노출(funnel) 시엔 true 유지 + 진짜 TLS 종료를 써야 한다.
AUTH_COOKIE_SECURE=false
